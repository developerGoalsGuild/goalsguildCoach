# Environment Variables for GoalsGuild Coach

# PostgreSQL Configuration
PGHOST=localhost
PGPORT=5432
PGDATABASE=goalsguild
PGUSER=postgres
PGPASSWORD=changeme

# OpenAI API Key (REQUIRED - add your key here!)
OPENAI_API_KEY=your-openai-api-key-here

# Server Configuration
PORT=3002
NODE_ENV=production

# Stripe (subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL for Stripe redirects (e.g. http://localhost:3002)
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Note: Copy this file to .env.local and add your keys.
# For local webhook testing: run `stripe listen --forward-to localhost:3002/api/webhooks/stripe`
# and set STRIPE_WEBHOOK_SECRET to the secret printed by the CLI.
